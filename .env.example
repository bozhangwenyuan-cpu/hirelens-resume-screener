SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
RESUME_SCREENER_LLM_PROVIDER=deepseek
RESUME_SCREENER_LLM_BASE_URL=https://api.deepseek.com
RESUME_SCREENER_MODEL=deepseek-v4-flash
RESUME_SCREENER_LLM_API_KEY=replace-with-your-api-key
RESUME_SCREENER_LLM_TIMEOUT=60
RESUME_SCREENER_VISION_TIMEOUT=90
RESUME_SCREENER_VISION_MAX_IMAGE_BYTES=358400
RESUME_SCREENER_VISION_MAX_TOKENS=1200

# Optional: image resume OCR/vision extraction, can use OpenAI-compatible vision APIs while keeping DeepSeek for screening
RESUME_SCREENER_VISION_BASE_URL=https://api.openai.com/v1
RESUME_SCREENER_VISION_MODEL=gpt-4.1-mini
RESUME_SCREENER_VISION_API_KEY=replace-with-openai-api-key

# Aliyun Bailian / DashScope example:
# RESUME_SCREENER_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# RESUME_SCREENER_VISION_MODEL=qwen-vl-plus
# RESUME_SCREENER_VISION_API_KEY=replace-with-dashscope-api-key

# Local Docker/SQLite fallback only
RESUME_SCREENER_HOST=0.0.0.0
RESUME_SCREENER_PORT=8765
RESUME_SCREENER_DB=/app/data/resume_screener.sqlite3
